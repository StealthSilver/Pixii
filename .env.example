# Copy this file to `.env.local` and fill in real values.
# Next.js loads `.env.local` automatically (do not commit it).

# --- Required for Hooks (library, drafts, seed) ---
# MongoDB Atlas → Database → Connect → Drivers → connection string.
# Replace <db_password> with your database user password (URL-encode special chars).
MONGODB_URI=mongodb+srv://USER:<db_password>@cluster.host.mongodb.net/pixii?retryWrites=true&w=majority

# Optional alias (same value as MONGODB_URI if your host only provides this name).
# DATABASE_URL=

# --- Required only for “Generate Posts” (Google Gemini) ---
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: model id (default: gemini-2.5-flash).
# GEMINI_MODEL=gemini-2.0-flash-001
