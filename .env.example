# Copy this file to `.env.local` and fill in real values.
# Next.js loads `.env.local` automatically (do not commit it).

# --- Required for Hooks (library, drafts, seed) ---
# MongoDB Atlas → Database → Connect → Drivers → connection string.
# Replace <db_password> with your database user password (URL-encode special chars).
MONGODB_URI=mongodb+srv://USER:<db_password>@cluster.host.mongodb.net/pixii?retryWrites=true&w=majority

# Optional alias (same value as MONGODB_URI if your host only provides this name).
# DATABASE_URL=

# --- Anthropic (Hooks “Generate Posts”, AEO diagnostic, Rufus Twin, Roaster, UGC vision, Review Analytics, Market Estimator) ---
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Default model for all of the above (override per feature below). Suggested: claude-haiku-4-5 (cost-friendly).
# ANTHROPIC_MODEL=claude-haiku-4-5

# Optional: use a stronger model for Rufus only (defaults to ANTHROPIC_MODEL).
# RUFUS_ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: Roaster listing score + script + scrape fallback (defaults to RUFUS_ANTHROPIC_MODEL, then ANTHROPIC_MODEL).
# ROASTER_ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: Review Analytics (purchase criteria + sentiment); defaults to ANTHROPIC_MODEL (not RUFUS_*).
# REVIEW_ANALYTICS_ANTHROPIC_MODEL=claude-haiku-4-5

# Optional: Market Estimator (scrape fallback + market insights JSON); defaults to ANTHROPIC_MODEL (not RUFUS_*).
# MARKET_ESTIMATOR_ANTHROPIC_MODEL=claude-haiku-4-5

# Optional: real Amazon HTML/reviews via ScraperAPI. Without it, listing + review text are Claude-generated placeholders (still useful for demos).
# SCRAPERAPI_KEY=

# --- Photo Upgrader (Replicate, Remove.bg, Cloudinary; Fal optional; Clipdrop optional) ---
# REPLICATE_API_KEY=
# REMOVEBG_API_KEY=
# CLIPDROP_API_KEY=   # optional — relight skipped when unset
# FAL_API_KEY=
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# --- AI Creator (/dashboard/ai-creator) ---
# Requires: MONGODB_URI, ANTHROPIC_API_KEY, ELEVEN_LABS_API_KEY (with text_to_speech), CLOUDINARY_*.
# Optional: SCRAPERAPI_KEY (real Amazon HTML), FAL_API_KEY (AI avatar frames + lip-sync video).
# Does not use Replicate, Remove.bg, or Clipdrop.

# --- Roaster (Amazon listing critique + voice + avatar) ---
# MongoDB + Cloudinary + ElevenLabs required. LLM: ANTHROPIC_API_KEY (same as Rufus).
# Uses SCRAPERAPI_KEY from Anthropic section when set for listing scrape fallback.
# https://elevenlabs.io/ — restricted API keys must allow Text-to-Speech (text_to_speech) or voiceover returns 401.
# ELEVEN_LABS_API_KEY=
# Same key, optional alternate env name:
# ELEVENLABS_API_KEY=
# Optional TTS model (default eleven_flash_v2). Was eleven_turbo_v2; Flash is the current recommendation.
# ELEVENLABS_TTS_MODEL_ID=eleven_flash_v2
# https://fal.ai/ (optional: static avatar frames if omitted)
# FAL_API_KEY=
# https://runware.ai/ — Roaster avatar when Fal quota is exceeded or unset (FLUX portrait + Kling avatar video).
# RUNWARE_API_KEY=
# Optional Runware talking-head model for Roaster (default klingai:avatar@2.0-pro).
# ROASTER_RUNWARE_AVATAR_MODEL=
# Share links use your app origin (e.g. http://localhost:3000 in dev).
# NEXTAUTH_URL=http://localhost:3000

# --- Clipper / Viral Video Chopper (/clipper, /api/video-chopper/*) ---
# Requires: MONGODB_URI, ANTHROPIC_API_KEY, REPLICATE_API_KEY, CLOUDINARY_CLOUD_NAME, CLOUDINARY_API_KEY, CLOUDINARY_API_SECRET.
# Strongly recommended when preview says “Video not available”: Google Cloud → enable YouTube Data API v3 → create an API key:
# YOUTUBE_API_KEY=
# Optional: JSON array of YouTube cookies (EditThisCookie export) so @distube/ytdl-core can download audio when YouTube bot-checks the server:
# YOUTUBE_COOKIES_JSON=
# Recommended for reliable audio downloads when ytdl shows “Something went wrong”: install yt-dlp + ffmpeg locally, then:
# YOUTUBE_DOWNLOAD_BACKEND=yt-dlp
# Optional path if yt-dlp is not on PATH (set to 0 to disable yt-dlp fallback in auto mode):
# YT_DLP_PATH=
# REPLICATE_API_KEY=   # Whisper transcription on Replicate (same key as Photo Upgrader if you use it there)
# Optional: real MP4 clips uploaded to Cloudinary (otherwise clips show “manual cut” with timestamps). Set to a Replicate model version ID whose API accepts { video, start_time, end_time } and returns a video URL.
# REPLICATE_VIDEO_TRIM_VERSION=
# Clip analysis + blog use Claude; model is RUFUS_ANTHROPIC_MODEL if set, else ANTHROPIC_MODEL, else default Haiku.
