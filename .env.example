# Copy this file to `.env.local` and fill in real values.
# Next.js loads `.env.local` automatically (do not commit it).

# --- Required for Hooks (library, drafts, seed) ---
# MongoDB Atlas → Database → Connect → Drivers → connection string.
# Replace <db_password> with your database user password (URL-encode special chars).
MONGODB_URI=mongodb+srv://USER:<db_password>@cluster.host.mongodb.net/pixii?retryWrites=true&w=majority

# Optional alias (same value as MONGODB_URI if your host only provides this name).
# DATABASE_URL=

# --- Required only for “Generate Posts” (Google Gemini) ---
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: model id (default: gemini-2.5-flash).
# GEMINI_MODEL=gemini-2.0-flash-001

# Optional: force Gemini REST API version — v1 or v1beta (default: try v1beta then v1).
# GEMINI_API_VERSION=v1

# --- AEO Diagnostic (OpenAI + Gemini) ---
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional: set to 1 to never call OpenAI (Gemini-only run, good when quota is out).
# Also hides the “OpenAI hit quota” demo banner when OpenAI is intentionally skipped.
# AEO_SKIP_OPENAI=1
# AEO_GEMINI_ONLY=1

# Optional: comma-separated Gemini model ids — AEO spreads parallel calls across models (separate free-tier RPM buckets).
# Default uses multiple Flash / Pro ids so one diagnostic does not exceed 5 RPM on a single model.
# AEO_GEMINI_BURST_MODELS=gemini-2.0-flash,gemini-2.5-flash,gemini-1.5-flash,gemini-2.0-flash-lite,gemini-2.5-flash-lite,gemini-1.5-flash-8b,gemini-pro

# Optional: try GEMINI_MODEL / AEO_GEMINI_MODEL before the built-in fallback list (default: built-in free-tier ids first).
# AEO_TRY_ENV_GEMINI_MODEL_FIRST=1
# AEO_GPT_MODEL=
# AEO_GPT_MINI_MODEL=
# AEO_GEMINI_MODEL=gemini-2.5-flash
# AEO_PARSER_MODEL=gpt-4o
# AEO_REC_MODEL=gpt-4o

# --- Rufus Twin (Claude / Anthropic Messages API) ---
# https://console.anthropic.com/
# ANTHROPIC_API_KEY=

# --- Photo Upgrader (Replicate, Remove.bg, Fal.ai, Clipdrop, Cloudinary) ---
# REPLICATE_API_KEY=
# REMOVEBG_API_KEY=
# CLIPDROP_API_KEY=
# FAL_API_KEY=
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
