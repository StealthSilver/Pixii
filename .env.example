# Copy this file to `.env.local` and fill in real values.
# Next.js loads `.env.local` automatically (do not commit it).

# --- Required for Hooks (library, drafts, seed) ---
# MongoDB Atlas → Database → Connect → Drivers → connection string.
# Replace <db_password> with your database user password (URL-encode special chars).
MONGODB_URI=mongodb+srv://USER:<db_password>@cluster.host.mongodb.net/pixii?retryWrites=true&w=majority

# Optional alias (same value as MONGODB_URI if your host only provides this name).
# DATABASE_URL=

# --- Anthropic (Hooks “Generate Posts”, AEO diagnostic, Rufus Twin, Roaster, UGC vision, Review Analytics) ---
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Default model for all of the above (override per feature below). Suggested: claude-haiku-4-5 (cost-friendly).
# ANTHROPIC_MODEL=claude-haiku-4-5

# Optional: use a stronger model for Rufus only (defaults to ANTHROPIC_MODEL).
# RUFUS_ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: Roaster listing score + script + scrape fallback (defaults to RUFUS_ANTHROPIC_MODEL, then ANTHROPIC_MODEL).
# ROASTER_ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: Review Analytics (purchase criteria + sentiment); defaults to ANTHROPIC_MODEL (not RUFUS_*).
# REVIEW_ANALYTICS_ANTHROPIC_MODEL=claude-haiku-4-5

# Optional: real Amazon HTML/reviews via ScraperAPI. Without it, listing + review text are Claude-generated placeholders (still useful for demos).
# SCRAPERAPI_KEY=

# --- Photo Upgrader (Replicate, Remove.bg, Fal.ai, Clipdrop, Cloudinary) ---
# REPLICATE_API_KEY=
# REMOVEBG_API_KEY=
# CLIPDROP_API_KEY=
# FAL_API_KEY=
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# --- Roaster (Amazon listing critique + voice + avatar) ---
# MongoDB + Cloudinary + ElevenLabs required. LLM: ANTHROPIC_API_KEY (same as Rufus).
# Uses SCRAPERAPI_KEY from Anthropic section when set for listing scrape fallback.
# https://elevenlabs.io/
# ELEVEN_LABS_API_KEY=
# Optional TTS model (default eleven_flash_v2). Was eleven_turbo_v2; Flash is the current recommendation.
# ELEVENLABS_TTS_MODEL_ID=eleven_flash_v2
# https://fal.ai/ (optional: static avatar frames if omitted)
# FAL_API_KEY=
# Share links use your app origin (e.g. http://localhost:3000 in dev).
# NEXTAUTH_URL=http://localhost:3000
